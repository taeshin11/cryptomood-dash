{
    "version": 2,
    "builds": [
        {
            "src": "**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "headers": {
                "Cache-Control": "public, max-age=300, s-maxage=600"
            }
        }
    ]
}
